# ── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database ────────────────────────────────────────────
# Local:  mongodb://127.0.0.1:27017/maison_lumiere
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>/maison_lumiere?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/maison_lumiere

# ── Auth ────────────────────────────────────────────────
# Generate a long random string: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# ── Admin bootstrap ─────────────────────────────────────
# Anyone who registers with this exact code becomes an admin.
# Keep it secret; owners share it only with staff.
ADMIN_SIGNUP_CODE=MAISON-ADMIN

# Seed script (npm run seed) creates this admin account + tables.
SEED_ADMIN_NAME=Margaux Vane
SEED_ADMIN_EMAIL=admin@maison.test
SEED_ADMIN_PASSWORD=change-me

# ── CORS ────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173
